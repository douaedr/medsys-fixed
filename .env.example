# =============================================
# MedSys - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS COMMITTER le fichier .env
# =============================================

# ── Base de données ────────────────────────────────────────────────────────
DB_USERNAME=medsys
DB_PASSWORD=medsys2026

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=medsys-hospital-jwt-secret-key-2026-very-long-and-secure-string-please-change-in-prod
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ── Email SMTP (Gmail) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── URLs inter-services (développement local) ─────────────────────────────
AUTH_SERVICE_URL=http://localhost:8081
PATIENT_SERVICE_URL=http://localhost:8082
MEDICAL_RECORD_SERVICE_URL=http://localhost:8083
APPOINTMENT_SERVICE_URL=http://localhost:8084
BILLING_SERVICE_URL=http://localhost:8085
NOTIFICATION_SERVICE_URL=http://localhost:8086

# ── Stockage fichiers ─────────────────────────────────────────────────────
UPLOAD_DIR=uploads/medical-records
