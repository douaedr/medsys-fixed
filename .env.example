# =============================================
# MedSys - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS COMMITTER le fichier .env
# =============================================

# Base de données
DB_USERNAME=root
DB_PASSWORD=
DB_AUTH_URL=jdbc:mysql://localhost:3307/ms_auth_db?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=UTF-8&serverTimezone=Africa/Casablanca
DB_PATIENT_URL=jdbc:mysql://localhost:3307/ms_patient_db?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=UTF-8&serverTimezone=Africa/Casablanca

# JWT (changer la clé en production !)
JWT_SECRET=remplacer-par-une-cle-secrete-longue-et-aleatoire-en-production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Email SMTP (ms-auth + ms-notify)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre.email@gmail.com
SMTP_PASSWORD=votre-app-password-gmail
# Alias utilisé par ms-notify
MAIL_USERNAME=votre.email@gmail.com
MAIL_PASSWORD=votre-app-password-gmail

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# CORS - origines autorisées (séparées par virgule)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# URL du frontend (utilisée dans les emails)
FRONTEND_URL=http://localhost:5173

# URLs inter-services
MS_AUTH_URL=http://localhost:8082
MS_PATIENT_URL=http://localhost:8081
MS_RDV_URL=http://localhost:8083
MS_NOTIFY_URL=http://localhost:8084

# Répertoire d'upload des fichiers patients
UPLOAD_DIR=uploads/patients
