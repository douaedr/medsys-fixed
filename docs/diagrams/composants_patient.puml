@startuml
title Diagramme de Composants - ms-patient-personnel
skinparam componentStyle rectangle

package "ms-patient-personnel (:8081)" {

  package "Controller Layer" {
    [PatientController\n/api/v1/patients] as PC
    [PatientPortalController\n/api/v1/patient] as PPC
    [DirecteurController\n/api/v1/directeur] as DC
    [AuthController\n/api/v1/auth] as AC
  }

  package "Security Layer" {
    [JwtAuthFilter] as JAF
    [SecurityConfig] as SC
    [JwtService] as JS
  }

  package "Service Layer" {
    [PatientService] as PS
    [DocumentService] as DOCS
    [MessageService] as MS
    [PdfService\n(OpenPDF)] as PDF
    [QrCodeService\n(ZXing)] as QR
    [RdvProxyService] as RDV
    [DirecteurService] as DS
  }

  package "Data Layer" {
    [PatientRepository] as PREPO
    [DossierMedicalRepository] as DREPO
    [DocumentPatientRepository] as DOCREP
    [MessagePatientRepository] as MREP
    [AnalyseRepository] as AREP
    [MedecinRepository] as MREPO
    database "ms_patient_db\n(MySQL :3307)" as DB
    folder "uploads/\n(fichiers)" as FS
  }

  package "Messaging Layer (RabbitMQ)" {
    [AppointmentEventListener\n(patient.rdv.queue)]      as AEL
    [UserCreatedEventListener\n(user.created.patient.queue)] as UCEL
    [NotificationPublisher]                               as NP
    [RabbitMQConfig\n(medsys.exchange)]                  as RMQCFG
    [AppointmentRecordRepository]                         as ARREPO
  }

  package "Mapper & Exceptions" {
    [PatientMapper] as MAP
    [GlobalExceptionHandler] as GEH
  }
}

[Frontend\n:5173] --> PC : REST HTTPS
[Frontend\n:5173] --> PPC : REST HTTPS
[Frontend\n:5173] --> DC : REST HTTPS
[Frontend\n:5173] --> AC : REST HTTPS
[App Mobile\n(Expo)] --> PPC : REST HTTP (Bearer Token)

SC --> JAF : filtre
JAF --> JS

PC --> PS
PPC --> PS
PPC --> DOCS
PPC --> MS
PPC --> PDF
PPC --> QR
PPC --> RDV
DC --> DS
DC --> PS
DC --> PDF
DC --> RDV
AC --> JS

PS --> PREPO
PS --> DREPO
PS --> MAP
DOCS --> DOCREP
DOCS --> DREPO
DOCS --> FS
MS --> MREP
DS --> PREPO
DS --> AREP
DS --> DOCREP
DS --> MREPO

PREPO --> DB
DREPO --> DB
DOCREP --> DB
MREP --> DB
AREP --> DB
MREPO --> DB
ARREPO --> DB

RDV --> [ms-rdv\n:8083] : REST HTTP

' ---- Consommation RabbitMQ ----
[RabbitMQ\nmedsys.exchange] as RMQ

RMQ ..> AEL  : patient.rdv.queue\n(appointment.created, appointment.cancelled)
RMQ ..> UCEL : user.created.patient.queue\n(user.created)

AEL  --> ARREPO : save AppointmentRecord
UCEL --> PREPO  : sync patient profile

' ---- Publication RabbitMQ ----
NP ..> RMQ : patient.notification\nappointment.rebook

note bottom of AEL
  Copie locale des RDV :
  table appointment_records
  (independance vis-a-vis ms-rdv)
end note

@enduml
